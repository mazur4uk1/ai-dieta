# Security
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Food Recognition API (Edamam)
# Nutrition Analysis API - provided by user
EDAMAM_APP_ID=b803dc99
EDAMAM_APP_KEY=50ba16cca84c4a5932779cc7c2a7e2e6

